        "NotEqual",
        "Greater",
        "GreaterOrEqual",
        "Less",
        "LessOrEqual",
        "Between"
      ],
      "enum": [
        0,
        1,
        2,
        3,
        4,
        5,
        6
      ]
    },
    "FilterRenderPlace": {
      "type": "integer",
      "description": "",
      "x-enumNames": [
        "Sidebar",
        "Header"
      ],
      "enum": [
        0,
        1
      ]
    },
    "LogicalOperator": {
      "type": "integer",
      "description": "",
      "x-enumNames": [
        "And",
        "Or"
      ],
      "enum": [
        0,
        1
      ]
