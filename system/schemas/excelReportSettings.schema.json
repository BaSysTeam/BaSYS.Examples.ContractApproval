        "null",
        "string"
      ]
    },
    "Title": {
      "type": [
        "null",
        "string"
      ]
    },
    "Memo": {
      "type": [
        "null",
        "string"
      ]
    },
    "IsActive": {
      "type": "boolean"
    },
    "Version": {
      "type": "integer",
      "format": "int64"
